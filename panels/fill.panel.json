        {
          "type": "numeric",
          "bind": { "kind": "selectionProperty", "path": "frameFillTint", "coerce": "%" },
          "min": 0,
          "max": 100,
          "label": { "key": "fill.tint" }
        }
      ]
    },
    {
      "title": { "key": "fill.gradient" },
