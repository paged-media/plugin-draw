{
  "$comment": "DESIGN PROTOTYPE — not interpreted by any host. Gradient rows depend on the gradient-assignment engine gap (BREAKAGE_LOG.md B-03): swatch fills bind today via frameFillColor colorRef; whether a Gradient/* self-id is accepted there is unverified.",
  "panel": "media.paged.draw.panel.fill",
  "title": { "key": "panel.fill.title" },
  "icon": "icons/fill.svg",
