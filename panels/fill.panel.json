      "rows": [
        {
          "type": "numeric",
          "bind": { "kind": "selectionProperty", "path": "frameGradientFillAngle" },
          "label": { "key": "gradient.angle" }
        },
        {
          "type": "numeric",
          "bind": { "kind": "selectionProperty", "path": "frameGradientFillLength", "coerce": "pt" },
          "label": { "key": "gradient.length" }
        }
      ]
    }
  ]
