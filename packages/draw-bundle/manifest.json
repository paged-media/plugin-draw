{
  "id": "media.paged.draw",
  "name": "paged.draw",
  "version": "0.2.2",
  "apiVersion": "^0.2",
  "publisher": "paged.media",
  "capabilities": {
    "document": {
      "read": "broad",
      "write": "scoped"
    },
    "rendering": [
      "overlay",
      "hitTest"
    ],
    "editContext": [
      "vectorGraphic"
    ],
    "network": false,
    "clipboard": "vector"
  },
  "contributes": {
    "tools": [
      "media.paged.draw.tool.addAnchor",
      "media.paged.draw.tool.deleteAnchor",
      "media.paged.draw.tool.convertAnchor"
    ],
    "panels": [
      "media.paged.draw.panel.stroke"
    ],
    "commands": [],
    "editContexts": [
      {
        "type": "vectorGraphic",
        "entry": "doubleClick"
      }
    ]
  }
}