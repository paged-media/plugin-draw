{
  "name": "@paged-media/draw",
  "private": false,
  "version": "0.1.0-canary.2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./geometry": "./src/geometry.ts",
    "./manifest.json": "./manifest.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "tsup",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@paged-media/plugin-api": "0.2.25-canary.0",
    "@paged-media/plugin-sdk": "0.2.25-canary.0"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@paged-media/draw-geometry": "workspace:*",
    "@paged-media/draw-tools": "workspace:*"
  },
  "files": [
    "dist",
    "manifest.json"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "canary",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./geometry": {
        "types": "./dist/geometry.d.ts",
        "default": "./dist/geometry.js"
      },
      "./manifest.json": "./manifest.json"
    }
  }
}
